{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cubelit",
  "version": "0.1.0",
  "identifier": "com.cubelit.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Cubelit",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri://localhost ipc: http://ipc.localhost; connect-src 'self' tauri://localhost ipc: http://ipc.localhost https://api.modrinth.com https://api.modpacks.ch; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https: blob:; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "recipes/*"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwMjJDMzZCNjI4RjExMjAKUldRZ0VZOWlhOE1pa0E4WkEvTTVhbVNDZi82ODRFTHlDQks5bzBpQmJvTFZjTVVzK1VDVW1jeEoK",
      "endpoints": [
        "https://github.com/UnHeardCoder/cubelit/releases/latest/download/latest.json"
      ],
      "dialog": false
    }
  }
}
